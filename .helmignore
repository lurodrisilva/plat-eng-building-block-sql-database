# Patterns to ignore when building packages.
# This supports shell glob matching, relative path matching, and
# negation (prefixed with !). Only one pattern per line.
.DS_Store
# Source control
.git/
.gitignore
# Common backup files
*.swp
*.bak
*.tmp
*.orig
*~
# IDEs
.project
.idea/
*.tmproj
.vscode/
# Helm build artifacts
Chart.lock
./charts/*
# Test infrastructure
tests/
# Repo tooling (not part of the chart)
Makefile
AGENTS.md
.sisyphus*
.github/
.yamllint.yml
